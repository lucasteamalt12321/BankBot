# Shared environment configuration example
# This file is SAFE to commit after replacing example values with non-secret team defaults.
# Copy to config/.env.shared and keep only non-secret/shared settings here.

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENV=development

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///data/bot.db
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_TIMEOUT=30

# =============================================================================
# PARSING SYSTEM
# =============================================================================
PARSING_ENABLED=false
PARSING_CHECK_INTERVAL=60

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
STRUCTURED_LOGGING=false

# =============================================================================
# NETWORK / PROXY
# =============================================================================
# Leave empty when using system-level VPN (e.g. AmneziaVPN).
PROXY_URL=

# =============================================================================
# BACKGROUND TASKS
# =============================================================================
TASK_CHECK_INTERVAL=300
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION=7

# =============================================================================
# SECURITY
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=20
SESSION_TIMEOUT=3600

# =============================================================================
# FEATURES
# =============================================================================
SHOP_ENABLED=true
GAMES_ENABLED=true
ACHIEVEMENTS_ENABLED=true
SOCIAL_FEATURES_ENABLED=true
DND_SYSTEM_ENABLED=false

# =============================================================================
# NOTIFICATIONS
# =============================================================================
ADMIN_NOTIFICATIONS_ENABLED=true
NOTIFICATION_COOLDOWN=300
NTFY_ENABLED=true
NTFY_BASE_URL=https://ntfy.sh
NTFY_TOPIC=lucasteam_bankbot_2091908459
NTFY_TAGS=loud_speaker,bank
NTFY_TIMEOUT_SECONDS=10
ADB_NOTIFICATIONS_ENABLED=false
ADB_PATH=adb
ADB_DEVICE_SERIAL=

# =============================================================================
# PERFORMANCE
# =============================================================================
CACHE_ENABLED=false
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# =============================================================================
# DEVELOPMENT
# =============================================================================
DEBUG=false
TEST_MODE=false
