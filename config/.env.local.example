# Local secret environment configuration example
# Copy to config/.env.local and fill with real secrets.
# NEVER commit config/.env.local.

# =============================================================================
# REQUIRED SECRETS / MACHINE-LOCAL VALUES
# =============================================================================
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-1234567890
ADMIN_TELEGRAM_ID=123456789

# =============================================================================
# OPTIONAL LOCAL OVERRIDES / SECRETS
# =============================================================================
BOT_TOKEN_BRIDGE=
BOT_USERNAME=
ADMIN_CHAT_ID=

# Bridge / VK
BRIDGE_ENABLED=false
BRIDGE_TG_CHAT_ID=0
TG_CHANNEL_ID=0
VK_TOKEN=
VK_PEER_ID=0
VK_GROUP_ID=0
BRIDGE_ADMIN_CHAT_ID=
