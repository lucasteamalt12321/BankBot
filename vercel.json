{
  "version": 2,
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/reading_trainer/(.*)",
      "dest": "/webapp/reading_trainer/$1"
    },
    {
      "src": "/reading_trainer",
      "dest": "/webapp/reading_trainer/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
